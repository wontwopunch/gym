# 복사 후 .env.local 로 저장해 로컬에서 쓰거나, Vercel 대시보드 Environment Variables 에 등록하세요.

# --- 상담 폼 이메일 (Resend: https://resend.com ) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=

# --- 관리자 로그인 (/admin) — 프로덕션에서는 반드시 강한 값으로 설정 ---
# 비워 두면 코드 기본값 admin / admin (이제 빈 칸만 있는 .env 도 동일)
ADMIN_SESSION_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 로컬 전용: 메일 없이 data/consultations.json 에만 저장 (production 에서는 사용 안 함)
# CONTACT_DEV_SAVE_WITHOUT_EMAIL=1
